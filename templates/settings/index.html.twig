{% extends 'base.html.twig' %}
{% block title %}Settings{% endblock %}
{% block body %}
    <h1 class="text-2xl font-bold mb-6">Settings</h1>

    <div class="grid gap-4 max-w-lg">
        <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-base">OpenRouter AI</h3>
                {% if hasOpenrouterKey %}
                    <span class="badge badge-success">Configured</span>
                {% else %}
                    <span class="badge badge-warning">Not configured</span>
                    <p class="text-sm text-base-content/50">Set OPENROUTER_API_KEY in .env.local for AI features.</p>
                {% endif %}
            </div>
        </div>

        <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-base">Notifications</h3>
                {% if hasNotifierDsn %}
                    <span class="badge badge-success">Configured</span>
                    <div class="mt-2 flex items-center gap-2">
                        <button
                            class="btn btn-sm btn-outline"
                            hx-post="{{ path('app_settings_test_notification') }}"
                            hx-headers='{"X-CSRF-Token": "{{ csrf_token('test_notification') }}"}'
                            hx-target="#test-notification-result"
                            hx-swap="innerHTML"
                        >
                            Send Test Notification
                        </button>
                        <span id="test-notification-result"></span>
                    </div>
                {% else %}
                    <span class="badge badge-warning">Not configured</span>
                    <p class="text-sm text-base-content/50">Set NOTIFIER_CHATTER_DSN in .env.local for notifications.</p>
                {% endif %}
            </div>
        </div>

        <form class="card bg-base-100 shadow-sm"
              hx-post="{{ path('app_settings_save') }}"
              hx-target="#save-result"
              hx-swap="innerHTML"
        >
            <div class="card-body">
                <h3 class="card-title text-base">Display Settings</h3>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('settings_save') }}">

                <div class="form-control">
                    <label class="label" for="setting-display-languages">
                        <span class="label-text">Display Languages</span>
                        {% if settings.display_languages.isOverridden %}
                            <span class="badge badge-info badge-xs">overridden</span>
                        {% else %}
                            <span class="badge badge-ghost badge-xs">default</span>
                        {% endif %}
                    </label>
                    <input type="text" id="setting-display-languages" name="display_languages"
                           value="{{ settings.display_languages.value }}"
                           class="input input-bordered input-sm"
                           placeholder="en,de,fr">
                    <label class="label">
                        <span class="label-text-alt text-base-content/50">Comma-separated language codes (e.g. en,de,fr)</span>
                    </label>
                </div>

                <div class="form-control">
                    <label class="label" for="setting-fetch-interval">
                        <span class="label-text">Fetch Interval (minutes)</span>
                        {% if settings.fetch_default_interval.isOverridden %}
                            <span class="badge badge-info badge-xs">overridden</span>
                        {% else %}
                            <span class="badge badge-ghost badge-xs">default</span>
                        {% endif %}
                    </label>
                    <input type="number" id="setting-fetch-interval" name="fetch_default_interval"
                           value="{{ settings.fetch_default_interval.value }}"
                           class="input input-bordered input-sm"
                           min="1" max="1440">
                    <label class="label">
                        <span class="label-text-alt text-base-content/50">Default interval between source fetches</span>
                    </label>
                </div>

                <div class="form-control">
                    <label class="label" for="setting-retention-articles">
                        <span class="label-text">Article Retention (days)</span>
                        {% if settings.retention_articles.isOverridden %}
                            <span class="badge badge-info badge-xs">overridden</span>
                        {% else %}
                            <span class="badge badge-ghost badge-xs">default</span>
                        {% endif %}
                    </label>
                    <input type="number" id="setting-retention-articles" name="retention_articles"
                           value="{{ settings.retention_articles.value }}"
                           class="input input-bordered input-sm"
                           min="1" max="365">
                    <label class="label">
                        <span class="label-text-alt text-base-content/50">Days to keep articles before cleanup</span>
                    </label>
                </div>

                <div class="form-control">
                    <label class="label" for="setting-retention-logs">
                        <span class="label-text">Log Retention (days)</span>
                        {% if settings.retention_logs.isOverridden %}
                            <span class="badge badge-info badge-xs">overridden</span>
                        {% else %}
                            <span class="badge badge-ghost badge-xs">default</span>
                        {% endif %}
                    </label>
                    <input type="number" id="setting-retention-logs" name="retention_logs"
                           value="{{ settings.retention_logs.value }}"
                           class="input input-bordered input-sm"
                           min="1" max="365">
                    <label class="label">
                        <span class="label-text-alt text-base-content/50">Days to keep notification and digest logs</span>
                    </label>
                </div>

                <div class="card-actions mt-2 flex items-center gap-2">
                    <button type="submit" class="btn btn-primary btn-sm">Save Settings</button>
                    <span id="save-result"></span>
                </div>
            </div>
        </form>

        <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-base">Color Scheme</h3>
                <p class="text-sm text-base-content/50">Saved in your browser. Changes apply immediately.</p>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mt-2">
                    <button data-theme-swatch="night" class="btn btn-sm h-auto py-3 flex flex-col gap-1 normal-case font-normal border border-base-content/10 hover:border-primary transition-all">
                        <span data-theme="night" class="w-full rounded px-2 py-1 bg-base-100 text-base-content text-xs text-left">
                            <span class="font-semibold">Aa</span> Dark Blue
                        </span>
                    </button>
                    <button data-theme-swatch="dracula" class="btn btn-sm h-auto py-3 flex flex-col gap-1 normal-case font-normal border border-base-content/10 hover:border-primary transition-all">
                        <span data-theme="dracula" class="w-full rounded px-2 py-1 bg-base-100 text-base-content text-xs text-left">
                            <span class="font-semibold">Aa</span> Dark Purple
                        </span>
                    </button>
                    <button data-theme-swatch="forest" class="btn btn-sm h-auto py-3 flex flex-col gap-1 normal-case font-normal border border-base-content/10 hover:border-primary transition-all">
                        <span data-theme="forest" class="w-full rounded px-2 py-1 bg-base-100 text-base-content text-xs text-left">
                            <span class="font-semibold">Aa</span> Dark Emerald
                        </span>
                    </button>
                    <button data-theme-swatch="winter" class="btn btn-sm h-auto py-3 flex flex-col gap-1 normal-case font-normal border border-base-content/10 hover:border-primary transition-all">
                        <span data-theme="winter" class="w-full rounded px-2 py-1 bg-base-100 text-base-content text-xs text-left">
                            <span class="font-semibold">Aa</span> Light Blue
                        </span>
                    </button>
                    <button data-theme-swatch="lemonade" class="btn btn-sm h-auto py-3 flex flex-col gap-1 normal-case font-normal border border-base-content/10 hover:border-primary transition-all">
                        <span data-theme="lemonade" class="w-full rounded px-2 py-1 bg-base-100 text-base-content text-xs text-left">
                            <span class="font-semibold">Aa</span> Light Warm
                        </span>
                    </button>
                    <button data-theme-swatch="valentine" class="btn btn-sm h-auto py-3 flex flex-col gap-1 normal-case font-normal border border-base-content/10 hover:border-primary transition-all">
                        <span data-theme="valentine" class="w-full rounded px-2 py-1 bg-base-100 text-base-content text-xs text-left">
                            <span class="font-semibold">Aa</span> Light Rose
                        </span>
                    </button>
                </div>
            </div>
        </div>

        <div class="card bg-base-100 shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-base">Quick Links</h3>
                <div class="flex flex-wrap gap-2">
                    <a href="{{ path('app_pipelines') }}" class="btn btn-sm btn-outline">Pipeline Status</a>
                    <a href="{{ path('app_sources') }}" class="btn btn-sm btn-outline">Sources</a>
                    <a href="{{ path('app_alerts') }}" class="btn btn-sm btn-outline">Alert Rules</a>
                    <a href="{{ path('app_digests') }}" class="btn btn-sm btn-outline">Digests</a>
                    <a href="{{ path('app_ai_stats') }}" class="btn btn-sm btn-outline">AI Stats</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
