{# Expects: label, value, description (optional), color (optional) #}
<div class="bg-base-100 rounded-lg shadow-sm p-4">
    <div class="text-xs text-base-content/60">{{ label }}</div>
    <div class="text-2xl font-bold text-{{ color|default('primary') }}">{{ value }}</div>
    {% if description is defined %}
        <div class="text-xs text-base-content/50">{{ description }}</div>
    {% endif %}
</div>
