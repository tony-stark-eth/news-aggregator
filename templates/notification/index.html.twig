{% extends 'base.html.twig' %}
{% block title %}Notification Log{% endblock %}
{% block body %}
    <h1 class="text-2xl font-bold mb-6">Notification Log</h1>

    <div class="flex gap-4 mb-6">
        <select name="rule" class="select select-bordered select-sm"
                hx-get="{{ path('app_notifications') }}"
                hx-target="#log-table"
                hx-include="[name='status']"
                hx-push-url="true">
            <option value="">All Rules</option>
            {% for alertRule in alertRules %}
                <option value="{{ alertRule.id }}" {{ ruleFilter == alertRule.id ? 'selected' }}>{{ alertRule.name }}</option>
            {% endfor %}
        </select>

        <select name="status" class="select select-bordered select-sm"
                hx-get="{{ path('app_notifications') }}"
                hx-target="#log-table"
                hx-include="[name='rule']"
                hx-push-url="true">
            <option value="">All Statuses</option>
            <option value="sent" {{ statusFilter == 'sent' ? 'selected' }}>Sent</option>
            <option value="skipped" {{ statusFilter == 'skipped' ? 'selected' }}>Skipped</option>
            <option value="failed" {{ statusFilter == 'failed' ? 'selected' }}>Failed</option>
        </select>
    </div>

    <div id="log-table">
        {% include 'notification/_log_table.html.twig' %}
    </div>
{% endblock %}
