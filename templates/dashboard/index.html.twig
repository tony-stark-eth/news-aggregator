{% extends 'base.html.twig' %}

{% block title %}Dashboard — News Aggregator{% endblock %}

{% block body %}
    {# Stats row #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        {% include 'components/_stat_widget.html.twig' with { label: 'Articles Today', value: articlesToday, color: 'primary' } %}
        {% include 'components/_stat_widget.html.twig' with { label: 'Active Sources', value: activeSources, color: 'secondary' } %}
        {% include 'components/_stat_widget.html.twig' with { label: 'Alerts Today', value: alertsToday, color: 'accent' } %}
        <div class="bg-base-100 rounded-lg shadow-sm p-4">
            <div class="text-xs text-base-content/60">Last Fetch</div>
            <div class="text-2xl font-bold text-info">
                {% if lastFetchedAt %}
                    <time class="timeago" datetime="{{ lastFetchedAt|date('c') }}">{{ lastFetchedAt|date('Y-m-d H:i') }}</time>
                {% else %}
                    never
                {% endif %}
            </div>
        </div>
    </div>

    {# Pipeline status — shows pending/failed counts so user knows why articles are "Rule" #}
    {% if pipelineStats is defined and pipelineStats and (pipelineStats.pending_fulltext > 0 or pipelineStats.pending_enrichment > 0 or pipelineStats.failed_fulltext > 0) %}
        <div class="alert alert-info alert-sm mb-4 py-2 text-sm">
            <span>Pipeline:
                {% if pipelineStats.pending_fulltext > 0 %}
                    {{ pipelineStats.pending_fulltext }} fetching content
                {% endif %}
                {% if pipelineStats.pending_enrichment > 0 %}
                    {{ pipelineStats.pending_fulltext > 0 ? ' · ' : '' }}{{ pipelineStats.pending_enrichment }} awaiting AI enrichment
                {% endif %}
                {% if pipelineStats.failed_fulltext > 0 %}
                    {{ (pipelineStats.pending_fulltext > 0 or pipelineStats.pending_enrichment > 0) ? ' · ' : '' }}<span class="text-warning">{{ pipelineStats.failed_fulltext }} content fetch failed</span>
                {% endif %}
            </span>
        </div>
    {% endif %}

    {# Category tabs #}
    <div id="category-tabs" class="tabs tabs-boxed mb-4 flex flex-nowrap overflow-x-auto">
        <a hx-get="{{ path('app_dashboard', {source: currentSource}) }}"
           hx-target="#article-feed"
           hx-swap="innerHTML"
           hx-push-url="true"
           hx-indicator="#feed-loader"
           class="tab whitespace-nowrap {{ currentCategory is null ? 'tab-active' : '' }}"
           hx-on:click="this.closest('.tabs').querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active')); this.classList.add('tab-active')">All{% if unreadCounts is defined and unreadCounts and unreadCounts.total > 0 %} ({{ unreadCounts.total }}){% endif %}</a>
        {% for category in categories %}
            {% set cat_unread = (unreadCounts is defined and unreadCounts) ? unreadCounts.categories[category.slug] ?? 0 : 0 %}
            <a hx-get="{{ path('app_dashboard', {category: category.slug, source: currentSource}) }}"
               hx-target="#article-feed"
               hx-swap="innerHTML"
               hx-push-url="true"
               hx-indicator="#feed-loader"
               class="tab whitespace-nowrap {{ currentCategory == category.slug ? 'tab-active' : '' }}"
               hx-on:click="this.closest('.tabs').querySelectorAll('.tab').forEach(t => t.classList.remove('tab-active')); this.classList.add('tab-active')">{{ category.name }}{% if cat_unread > 0 %} ({{ cat_unread }}){% endif %}</a>
        {% endfor %}
    </div>

    {# Source filter dropdown #}
    <div class="mb-4">
        <select class="select select-bordered select-sm w-full max-w-xs"
                hx-on:change="window.location.href = this.value"
                aria-label="Filter by source">
            <option value="{{ path('app_dashboard', {category: currentCategory, unreadOnly: unreadOnly ? 1 : 0, bookmarkedOnly: bookmarkedOnly|default(false) ? 1 : 0}) }}"
                    {{ currentSource is null ? 'selected' : '' }}>All Sources</option>
            {% for source in sources %}
                <option value="{{ path('app_dashboard', {category: currentCategory, unreadOnly: unreadOnly ? 1 : 0, bookmarkedOnly: bookmarkedOnly|default(false) ? 1 : 0, source: source.id}) }}"
                        {{ currentSource == source.id ? 'selected' : '' }}>{{ source.name }}</option>
            {% endfor %}
        </select>
    </div>

    {# Unread filter + Bookmarked filter + Mark all read #}
    <div id="filter-bar" class="flex items-center gap-3 mb-4">
        {% include 'dashboard/_filter_bar.html.twig' with {
            currentCategory: currentCategory,
            currentSource: currentSource,
            unreadOnly: unreadOnly,
            bookmarkedOnly: bookmarkedOnly|default(false),
        } %}
    </div>

    {# New articles banner (shown via Mercure SSE) #}
    <div id="new-articles-banner" class="alert alert-info mb-4 hidden cursor-pointer" role="button">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span id="new-articles-count"></span>
    </div>

    {# Loading indicator #}
    <div id="feed-loader" class="htmx-indicator flex justify-center py-4">
        <span class="loading loading-spinner loading-lg text-primary"></span>
    </div>

    {# Article feed #}
    {% if articles is empty %}
        {% include 'components/_empty_state.html.twig' with {
            message: 'No articles yet — configure your sources and fetch some feeds.',
            action_label: 'Manage Sources',
            action_url: path('app_sources')
        } %}
    {% else %}
        <div id="article-feed" class="flex flex-col gap-3">
            {% for article in articles %}
                {% include 'components/_article_card.html.twig' %}
            {% endfor %}
            {% include 'components/_pagination_loader.html.twig' with {
                currentPage: page,
                currentCategory: currentCategory,
                unreadOnly: unreadOnly,
                bookmarkedOnly: bookmarkedOnly|default(false),
                hasMore: articles|length >= 20,
            } %}
        </div>
    {% endif %}
{% endblock %}
