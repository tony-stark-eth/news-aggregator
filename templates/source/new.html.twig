{% extends 'base.html.twig' %}
{% block title %}New Source{% endblock %}
{% block body %}
    <h1 class="text-2xl font-bold mb-6">New Source</h1>

    <form method="POST" action="{{ path('app_sources_new') }}" class="max-w-lg flex flex-col gap-4">
        <div class="form-control">
            <label class="label" for="name">
                <span class="label-text">Name</span>
            </label>
            <input type="text" id="name" name="name" class="input input-bordered" required placeholder="e.g. Ars Technica">
        </div>

        <div class="form-control">
            <label class="label" for="feed_url">
                <span class="label-text">Feed URL</span>
            </label>
            <div class="flex gap-2">
                <input type="url" id="feed_url" name="feed_url" class="input input-bordered flex-1" required placeholder="https://example.com/feed.xml">
                <button type="button"
                        class="btn btn-outline btn-sm self-center"
                        hx-post="{{ path('app_sources_validate_url') }}"
                        hx-include="[name=feed_url], [name=_validate_token]"
                        hx-target="#feed-preview"
                        hx-indicator="#validate-spinner">
                    <span class="htmx-indicator loading loading-spinner loading-xs" id="validate-spinner"></span>
                    Validate
                </button>
            </div>
            <input type="hidden" name="_validate_token" value="{{ csrf_token('validate_feed_url') }}">
            <div id="feed-preview"></div>
        </div>

        <div class="form-control">
            <label class="label" for="site_url">
                <span class="label-text">Site URL (optional)</span>
            </label>
            <input type="url" id="site_url" name="site_url" class="input input-bordered" placeholder="https://example.com">
        </div>

        <div class="form-control">
            <label class="label" for="category_id">
                <span class="label-text">Category</span>
            </label>
            <select id="category_id" name="category_id" class="select select-bordered" required>
                {% for category in categories %}
                    <option value="{{ category.id }}">{{ category.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="form-control">
            <label class="label" for="language">
                <span class="label-text">Language (optional)</span>
            </label>
            <select id="language" name="language" class="select select-bordered">
                <option value="">Auto-detect</option>
                <option value="en">English</option>
                <option value="de">German</option>
                <option value="fr">French</option>
                <option value="es">Spanish</option>
            </select>
        </div>

        <div class="form-control">
            <label class="label" for="fetch_interval_minutes">
                <span class="label-text">Fetch Interval (optional, 5-1440 minutes)</span>
            </label>
            <input type="number" id="fetch_interval_minutes" name="fetch_interval_minutes" class="input input-bordered" min="5" max="1440" placeholder="Use default">
        </div>

        <div class="form-control">
            <label class="label" for="reliability_weight">
                <span class="label-text">Reliability Weight (optional, 0.0-1.0)</span>
            </label>
            <input type="number" id="reliability_weight" name="reliability_weight" class="input input-bordered" min="0" max="1" step="0.1" placeholder="Default (0.7)">
            <span class="label-text-alt text-xs opacity-70">Affects article scoring — higher means more trusted source</span>
        </div>

        <div class="form-control">
            <label class="label cursor-pointer justify-start gap-3">
                <input type="checkbox" name="enabled" value="1" class="checkbox" checked>
                <span class="label-text">Enabled</span>
            </label>
        </div>

        <div class="form-control">
            <label class="label cursor-pointer justify-start gap-3">
                <input type="checkbox" name="full_text_enabled" value="1" class="checkbox" checked id="full_text_enabled">
                <span class="label-text">Full-text fetch</span>
            </label>
            <span class="label-text-alt text-xs opacity-70 ml-9">Fetch full article content from the source website</span>
        </div>

        <div class="flex gap-2 mt-2">
            <button type="submit" class="btn btn-primary">Create Source</button>
            <a href="{{ path('app_sources') }}" class="btn btn-ghost">Cancel</a>
        </div>
    </form>

    <script>
        document.getElementById('feed-preview')?.addEventListener('htmx:afterSwap', function () {
            const preview = this.querySelector('[data-detected-language]');
            if (!preview) return;
            const lang = preview.dataset.detectedLanguage;
            const select = document.getElementById('language');
            if (lang && select && select.value === '') {
                select.value = lang;
            }

            const fullContentIndicator = this.querySelector('[data-has-full-content]');
            const fullTextCheckbox = document.getElementById('full_text_enabled');
            if (fullContentIndicator && fullTextCheckbox) {
                fullTextCheckbox.checked = false;
            }
        });
    </script>
{% endblock %}
