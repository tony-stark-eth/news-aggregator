{% extends 'base.html.twig' %}
{% block title %}AI Model Stats{% endblock %}
{% block body %}
    <h1 class="text-2xl font-bold mb-6">AI Model Statistics</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <div class="card bg-base-200 shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-sm font-semibold text-base-content/70">Primary Model</h3>
                <p class="font-mono text-sm">{{ primaryModel }}</p>
            </div>
        </div>

        <div class="card bg-base-200 shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-sm font-semibold text-base-content/70">Paid Fallback</h3>
                <p class="font-mono text-sm">{{ paidFallbackModel ?: 'Not configured' }}</p>
            </div>
        </div>

        <div class="card bg-base-200 shadow-sm">
            <div class="card-body p-4">
                <h3 class="text-sm font-semibold text-base-content/70">Blocked Models</h3>
                {% if blockedModels is empty %}
                    <p class="text-sm text-base-content/50">None</p>
                {% else %}
                    <div class="flex flex-wrap gap-1 mt-1">
                        {% for model in blockedModels %}
                            <span class="badge badge-error badge-sm font-mono">{{ model }}</span>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% if stats is empty %}
        <div class="alert alert-info mb-6">No model quality data yet. Stats populate after AI enrichment runs.</div>
    {% else %}
        <div class="overflow-x-auto mb-8">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Model</th>
                        <th>Accepted</th>
                        <th>Rejected</th>
                        <th>Rate</th>
                    </tr>
                </thead>
                <tbody>
                    {% for model, data in stats %}
                        <tr>
                            <td class="font-mono text-sm">{{ model }}</td>
                            <td>{{ data.accepted }}</td>
                            <td>{{ data.rejected }}</td>
                            <td>
                                <div class="flex items-center gap-2">
                                    <progress class="progress {{ data.acceptanceRate > 0.7 ? 'progress-success' : (data.acceptanceRate > 0.4 ? 'progress-warning' : 'progress-error') }} w-20" value="{{ (data.acceptanceRate * 100)|round }}" max="100"></progress>
                                    <span class="text-sm">{{ (data.acceptanceRate * 100)|round(1) }}%</span>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <h2 class="text-xl font-bold mb-4">Available Free Models ({{ freeModels|length }})</h2>
    {% if freeModels is empty %}
        <div class="alert alert-warning">No free models discovered. Circuit breaker may be open or API unreachable.</div>
    {% else %}
        <div class="flex flex-wrap gap-2">
            {% for model in freeModels %}
                <span class="badge badge-outline">{{ model.value }}</span>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
