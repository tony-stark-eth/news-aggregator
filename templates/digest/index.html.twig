{% extends 'base.html.twig' %}
{% block title %}Digests{% endblock %}
{% block body %}
    <h1 class="text-2xl font-bold mb-6">Digest Configuration</h1>

    {% if configs is empty %}
        {% include 'components/_empty_state.html.twig' with {
            message: 'No digest configurations yet.'
        } %}
    {% else %}
        <div class="overflow-x-auto mb-8">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Schedule</th>
                        <th>Categories</th>
                        <th>Limit</th>
                        <th>Last Run</th>
                        <th>Enabled</th>
                    </tr>
                </thead>
                <tbody>
                    {% for config in configs %}
                        <tr>
                            <td class="font-bold">{{ config.name }}</td>
                            <td><code>{{ config.schedule }}</code></td>
                            <td>{{ config.categories|join(', ') ?: 'All' }}</td>
                            <td>{{ config.articleLimit }}</td>
                            <td>
                                {% if config.lastRunAt %}
                                    <time datetime="{{ config.lastRunAt|date('c') }}" class="timeago">{{ config.lastRunAt|date('Y-m-d H:i') }}</time>
                                {% else %}
                                    <span class="text-base-content/30">never</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if config.enabled %}
                                    <span class="badge badge-success badge-sm">yes</span>
                                {% else %}
                                    <span class="badge badge-ghost badge-sm">no</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <h2 class="text-xl font-bold mb-4">Recent Digest History</h2>
    {% if recentLogs is empty %}
        <p class="text-base-content/50">No digests generated yet.</p>
    {% else %}
        <div class="flex flex-col gap-3">
            {% for log in recentLogs %}
                <div class="collapse collapse-arrow bg-base-100 shadow-sm">
                    <input type="checkbox" />
                    <div class="collapse-title flex items-center gap-3">
                        <span class="font-bold">{{ log.digestConfig.name }}</span>
                        <time datetime="{{ log.generatedAt|date('c') }}" class="text-sm text-base-content/50 timeago">{{ log.generatedAt|date('Y-m-d H:i') }}</time>
                        <span class="badge badge-sm">{{ log.articleCount }} articles</span>
                        {% if log.deliverySuccess %}
                            <span class="badge badge-success badge-sm">delivered</span>
                        {% else %}
                            <span class="badge badge-error badge-sm">failed</span>
                        {% endif %}
                    </div>
                    <div class="collapse-content">
                        <pre class="text-sm whitespace-pre-wrap">{{ log.content }}</pre>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
