# News Aggregator — Environment Variables
# Copy to .env.local and adjust values

# Symfony
APP_ENV=dev
APP_SECRET=change-me-to-a-random-string

# Database (PostgreSQL)
POSTGRES_VERSION=17
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=!ChangeMe!

# Admin user (default: demo@localhost / demo)
ADMIN_EMAIL=demo@localhost
ADMIN_PASSWORD_HASH='$2y$12$M9bYgEuL2NVffm.iz4JalOd8ePY3JDtMQEvvaK7zL8tFVy6PgRa3a'

# OpenRouter AI (optional — rule-based fallback works without it)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_BLOCKED_MODELS=

# Notifications (install desired transport package)
# Pushover: pushover://USER_KEY:APP_TOKEN@default
# Slack: slack://TOKEN@default?channel=CHANNEL
# Telegram: telegram://TOKEN@default?channel=CHAT_ID
NOTIFIER_CHATTER_DSN=null://null

# Data retention (days)
RETENTION_ARTICLES=90
RETENTION_LOGS=30

# Feed fetching (default interval; per-category overrides in DB)
FETCH_DEFAULT_INTERVAL_MINUTES=15

# Docker ports
HTTP_PORT=8180
HTTPS_PORT=8443
